{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Hubble",
	"version": "0.1.0",
	"identifier": "com.benholmes.hubblemd.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Hubble",
				"width": 800,
				"height": 600,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"trafficLightPosition": { "x": 16, "y": 16 }
			}
		],
		"security": {
			"csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: http: https: asset: http://asset.localhost",
			"assetProtocol": {
				"enable": true,
				"scope": ["$HOME/**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"fileAssociations": [
			{
				"name": "Markdown Document",
				"description": "Markdown text file",
				"ext": ["md", "markdown", "mdown"],
				"role": "Editor",
				"rank": "Owner"
			}
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
