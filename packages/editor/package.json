{
	"name": "@sudomd/editor",
	"version": "0.0.1",
	"description": "Framework-agnostic Markdown editor core for Sudomd",
	"license": "MIT",
	"author": "Ahmed Rowaihi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmedrowaihi/sudomd.git",
		"directory": "packages/editor"
	},
	"homepage": "https://sudomd",
	"bugs": "https://github.com/ahmedrowaihi/sudomd/issues",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"test": "vitest run"
	},
	"dependencies": {
		"@tiptap/core": "^3.4.3",
		"@tiptap/extension-list": "^3.4.2",
		"@tiptap/pm": "^3.3.0",
		"hast-util-from-html": "^2.0.3",
		"rehype-parse": "^9.0.1",
		"rehype-remark": "^10.0.1",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.1",
		"remark-stringify": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/unist": "^3.0.3",
		"typescript": "~5.8.3",
		"vitest": "^3.2.4"
	}
}
