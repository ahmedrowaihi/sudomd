{
	"name": "@sudomd/ui",
	"version": "0.0.1",
	"private": true,
	"description": "Shared React editor UI for Sudomd",
	"license": "MIT",
	"author": "Ahmed Rowaihi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmedrowaihi/sudomd.git",
		"directory": "packages/ui"
	},
	"homepage": "https://sudomd",
	"bugs": "https://github.com/ahmedrowaihi/sudomd/issues",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./style.css": "./dist/index.css",
		"./tailwind.css": "./dist/tailwind.css",
		"./theme.css": "./dist/theme.css",
		"./fonts.css": "./dist/fonts.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "vite build --watch",
		"test": "vitest run"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@dnd-kit/core": "^6.3.1",
		"@floating-ui/dom": "^1.7.5",
		"@sudomd/editor": "workspace:*",
		"@tiptap/core": "^3.4.3",
		"@tiptap/extension-code-block-lowlight": "3.20.0",
		"@tiptap/extension-document": "3.20.0",
		"@tiptap/extension-highlight": "3.20.0",
		"@tiptap/extension-list": "^3.4.2",
		"@tiptap/extension-table": "3.20.0",
		"@tiptap/extension-typography": "3.20.0",
		"@tiptap/pm": "^3.3.0",
		"@tiptap/react": "^3.3.0",
		"@tiptap/starter-kit": "^3.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"cnfast": "^0.0.8",
		"highlight.js": "^11.11.1",
		"keymatch": "^1.0.5",
		"lowlight": "^3.3.0",
		"mermaid": "^11.16.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@iconify-json/mingcute": "^1.2.7",
		"@types/react": "^19.1.8",
		"happy-dom": "^20.10.3",
		"typescript": "~5.8.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.0.4",
		"vitest": "^3.2.4"
	}
}
